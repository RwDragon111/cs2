APP_ENV=production
DATABASE_URL=sqlite:///data/cs2_arbitrage.db

# Telegram
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
AUTHORIZED_TELEGRAM_ID=123456789

# Market API keys. Keep secrets only in .env, never in code.
DMARKET_API_KEY=
DMARKET_API_SECRET=
CSGO_MARKET_API_KEY=

# Optional legacy names kept for compatibility with older modules.
DMARKET_PUBLIC_KEY=
DMARKET_SECRET_KEY=
MARKET_CSGO_API_KEY=

# Market endpoints. Verify against official docs before enabling real trading.
DMARKET_API_BASE_URL=https://api.dmarket.com
DMARKET_ITEMS_ENDPOINT=/exchange/v1/market/items
MARKET_CSGO_BASE_URL=https://market.csgo.com
CSGO_MARKET_BUY_ORDERS_ENDPOINT=/api/v2/prices/orders/RUB.json
CSGO_MARKET_BALANCE_ENDPOINT=/api/v2/get-money

# Safe local testing
USE_MOCK_MARKETS=false

# Scanner filters
SCAN_INTERVAL_SECONDS=300
MIN_PROFIT_PERCENT=5
MIN_PROFIT_ABSOLUTE=100
MIN_ITEM_PRICE=300
MAX_ITEM_PRICE=50000
MIN_LIQUIDITY_SCORE=60
MAX_PRICE_SPIKE_PERCENT=25
PRICE_HISTORY_DAYS=30

# Fees, percent
DMARKET_FEE_PERCENT=0
CSGO_MARKET_FEE_PERCENT=5
WITHDRAWAL_FEE_PERCENT=0

# Trade lock
TRADE_LOCK_DAYS=8

# DEMO/REAL mode
DEFAULT_TRADING_MODE=DEMO
ALLOW_REAL_TRADING=false
DEMO_INITIAL_BALANCE=100000
DEMO_CURRENCY=RUB

# Currency conversion for DMarket USD prices
BASE_CURRENCY=RUB
SECONDARY_CURRENCY=USD
RUB_USD_RATE_SOURCE=manual
MANUAL_RUB_USD_RATE=100

# Limits and API behavior
REQUEST_TIMEOUT_SECONDS=20
MAX_API_RETRIES=3
DMARKET_STATS_LIMIT=100

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Older scheduler settings kept for compatibility with existing tests/modules.
TELEGRAM_ADMIN_CHAT_ID=
TRADING_MODE=PAPER_TRADING
PAPER_TRADING_ENABLED=true
PAPER_TRADING_INITIAL_BALANCE_RUB=10000
PAPER_TRADING_INITIAL_BALANCE_USD=20
PAPER_TRADING_ALLOW_NEGATIVE_BALANCE=false
PAPER_TRADING_RESET_ON_START=false
PAPER_TRADING_TRADE_BAN_DAYS=8
PAPER_TRADING_SELL_MODE=MANUAL_SELL
PAPER_TRADING_USE_REAL_MARKET_PRICE_ON_SELL=true
MARKET_POLL_INTERVAL_SECONDS=30
OPPORTUNITY_SCAN_INTERVAL_SECONDS=35
PAPER_POSITION_CHECK_INTERVAL_SECONDS=300
SALES_HISTORY_INTERVAL_SECONDS=900
