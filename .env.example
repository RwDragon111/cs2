APP_ENV=production

DATABASE_URL=sqlite:///data/cs2_arbitrage.db

TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

USE_MOCK_MARKETS=false

MARKET_CSGO_API_KEY=
DMARKET_PUBLIC_KEY=
DMARKET_SECRET_KEY=

ENABLE_MARKET_CSGO=true
ENABLE_DMARKET=true
ENABLE_THIRD_MARKET=false
ENABLE_DMARKET_STATS=false
DMARKET_STATS_LIMIT=100
DMARKET_STATS_CURRENCY=USD
DMARKET_STATS_TITLES=AWP | Asiimov (Field-Tested),AK-47 | Redline (Field-Tested),M4A1-S | Printstream (Minimal Wear),Desert Eagle | Printstream (Field-Tested),USP-S | Kill Confirmed (Field-Tested)
ENABLE_STATS_SPREAD_SIGNALS=false
MIN_STATS_SPREAD_PERCENT=8.0
MIN_STATS_ABSOLUTE_SPREAD_RUB=100
MAX_STATS_SIGNALS_PER_SCAN=5

TRADING_MODE=PAPER_TRADING

PAPER_TRADING_ENABLED=true
PAPER_TRADING_INITIAL_BALANCE_RUB=10000
PAPER_TRADING_INITIAL_BALANCE_USD=20
PAPER_TRADING_ALLOW_NEGATIVE_BALANCE=false
PAPER_TRADING_RESET_ON_START=false
PAPER_TRADING_TRADE_BAN_DAYS=7
PAPER_TRADING_SELL_MODE=MANUAL_SELL
PAPER_TRADING_USE_REAL_MARKET_PRICE_ON_SELL=true

BASE_CURRENCY=RUB
SECONDARY_CURRENCY=USD
RUB_USD_RATE_SOURCE=manual
MANUAL_RUB_USD_RATE=100

MIN_PROFIT_RUB=100
MIN_PROFIT_USD=1.00
MIN_ROI_PERCENT=5.0

MAX_BUY_PRICE_RUB=10000
MAX_BUY_PRICE_USD=100

MAX_DAILY_SPEND_RUB=10000
MAX_OPEN_POSITIONS=10

RISK_BUFFER_PERCENT=2.0
CURRENCY_SPREAD_PERCENT=1.0
MAX_ALLOWED_CURRENCY_SPREAD_PERCENT=2.0

MIN_LIQUIDITY_SCORE=60

ALLOW_MARKETS_WITH_CRYPTO_ONLY=true
MAX_PAYMENT_CONVERSION_FEE_PERCENT=2.0
MAX_DEPOSIT_FEE_PERCENT=2.0
MAX_WITHDRAWAL_FEE_PERCENT=3.0

EXCLUDED_MARKETS=CS.MONEY,csmoney,cs.money,White.Market,white.market
OPTIONAL_MARKET_CANDIDATES=Waxpeer,BitSkins,Skinport,CSFloat

LOG_LEVEL=INFO
LOG_FILE=logs/app.log

MARKET_POLL_INTERVAL_SECONDS=30
OPPORTUNITY_SCAN_INTERVAL_SECONDS=35
PAPER_POSITION_CHECK_INTERVAL_SECONDS=300
SALES_HISTORY_INTERVAL_SECONDS=900
