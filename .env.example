# Secrets and identity only. Market filters are stored in data/settings.json
# and can be changed from Telegram with /set.

TELEGRAM_BOT_TOKEN=
AUTHORIZED_TELEGRAM_ID=123456789

# Optional API keys. Public scanning works without LIS_SKINS_API_KEY.
LIS_SKINS_API_KEY=
CSGO_MARKET_API_KEY=

# Optional legacy/alternative keys kept for compatibility.
DMARKET_API_KEY=
DMARKET_API_SECRET=
DMARKET_PUBLIC_KEY=
DMARKET_SECRET_KEY=
MARKET_CSGO_API_KEY=
